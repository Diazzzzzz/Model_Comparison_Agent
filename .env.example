# ========= 车型对比 Agent · 环境变量 =========
# 复制本文件为 .env，把下面的 key 填进去即可。
# 不填任何 key 也能跑：程序会自动进入【演示模式(MOCK)】，用内置样例数据走通全流程。

# --- 文本模型：DeepSeek（生成对比表 / 话术 / H5文案）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 图像模型：火山方舟 豆包·文生图 Seedream（生成 H5 场景背景图，可选）---
# 申请地址：火山引擎方舟控制台。不填则 H5 用内置的 SVG 场景背景兜底（不是灰占位）。
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-3-0-t2i-250415

# 强制演示模式（即使填了 key 也不真调模型），调 UI 时用：设为 1 开启
FORCE_MOCK=0

# --- 自动抠图（去背景）质量调节，可选 ---
# 抠图效果不好时调这两个：
# REMBG_MODEL：默认 isnet-general-use。想要最好效果设 birefnet-general（模型大、更慢）
REMBG_MODEL=isnet-general-use
# REMBG_ALPHA：设 1 开启边缘精修(alpha matting)，边更细但更慢
REMBG_ALPHA=0
